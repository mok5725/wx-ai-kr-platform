# wx.ai.kr 플랫폼 통합 env — 서버 /opt/wx-ai-kr/.env 로 복사 후 값 입력(커밋 금지).
# 비밀 생성: python3 -c "import secrets;print(secrets.token_urlsafe(32))"
# Fernet 키:  python3 -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"

# === 이미지 태그(평소 latest, 버전 고정 시 sha-XX: 형태로) ===
LAB_IMAGE_TAG=latest
DX_IMAGE_TAG=latest

# === lab(wx01) DB ===
LAB_POSTGRES_USER=wxuser
LAB_POSTGRES_PASSWORD=__GENERATE__
LAB_POSTGRES_DB=wxdb
# === lab 앱 ===
LAB_JWT_SECRET=__GENERATE__
LAB_JWT_EXPIRE_HOURS=12
LAB_ADMIN_PASSWORD=__CHANGE_ME__

# === dx DB ===
DX_POSTGRES_USER=dxuser
DX_POSTGRES_PASSWORD=__GENERATE__
DX_POSTGRES_DB=dxdb
# === dx 앱(core) ===
DX_JWT_SECRET=__GENERATE__
DX_JWT_EXPIRE_HOURS=8
DX_ENCRYPTION_KEY=__GENERATE_FERNET__
DX_INITIAL_ADMIN_EMAIL=admin@example.com
DX_INITIAL_ADMIN_PASSWORD=__CHANGE_ME__
DX_OPENAI_API_KEY=
DX_OPENAI_MODEL=gpt-4o-mini
DX_GEMINI_API_KEY=
# === dx 앱(board/소통방) ===
DX_BOARD_ADMIN_ID=instructor
DX_BOARD_ADMIN_PW=__CHANGE_ME__
DX_BOARD_SECRET_KEY=__GENERATE_32_PLUS__
DX_BOARD_SESSION_HOURS=12
# public_base_url(https://talk.wx.ai.kr)·COOKIE_DOMAIN(wx.ai.kr)은 compose에 고정.
